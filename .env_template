# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Anthropic API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Piazza account (the bot's login) ──────────────────────────────────────────
PIAZZA_EMAIL=your_piazza_bot_email@example.com
PIAZZA_PASSWORD=your_piazza_password

# ── Piazza network IDs (found in the Piazza class URL) ────────────────────────
# Primary course (bot.py):
PIAZZA_NETWORK=your_primary_network_id
# Alias accepted by bot.py (either works):
# PIAZZA_NETWORK_COGS9=your_primary_network_id

# Secondary course (assistant_b.py) — optional:
# CHEM_PIAZZA_NETWORK=your_secondary_network_id
# PIAZZA_NETWORK_CHEM11=your_secondary_network_id

# ── Email notifications ────────────────────────────────────────────────────────
# Gmail address that receives a confirmation every time the bot posts.
NOTIFY_EMAIL=your@gmail.com
# Gmail App Password (Settings → Security → 2-Step Verification → App Passwords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Optional tuning ───────────────────────────────────────────────────────────
# Seconds between scans (default: 120)
# POLL_INTERVAL=120
# Path to syllabus file (default: syllabus.txt)
# SYLLABUS_PATH=syllabus.txt
# Path to secondary syllabus (default: syllabus_b.txt)
# CHEM_SYLLABUS_PATH=syllabus_b.txt
# Post limit for secondary bot before it shuts down (default: 10)
# CHEM_CONTENT_LIMIT=10

# ── Canvas context (CHEM 11 bot — assistant_b.py) ─────────────────────────────
# All variables below are OPTIONAL. If absent, the CHEM 11 bot falls back to
# local cache then no-context answering — it never crashes.
# Cookies come from running: python canvas_login.py
# (UCSD disables personal access tokens; cookie auth is required.)
#
# Path to the persisted Canvas session-cookie file (written by canvas_login.py):
# CANVAS_COOKIES_PATH=canvas_cookies.json
# Numeric Canvas course ID for CHEM 11 (found in the Canvas course URL):
# CHEM_CANVAS_COURSE_ID=your_chem11_course_id
# Canvas REST API base URL:
# CANVAS_API_BASE=https://canvas.ucsd.edu/api/v1
# Local crawled Canvas cache directory (fallback when session is expired):
# CANVAS_LOCAL_CACHE_DIR=~/.claude/canvas-cache
# TTL in hours for the module's own live-response cache (default: 6):
# CANVAS_CACHE_TTL_HOURS=6
